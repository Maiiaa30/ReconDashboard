{
  "manifest_version": 3,
  "name": "Recon Dashboard — Capture",
  "version": "0.1.0",
  "description": "Passively captures requests to your tracked targets and sends them to the Recon Dashboard for replay. Nothing else is sent.",
  "permissions": ["webRequest", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Recon Capture",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "recon-capture@recondashboard",
      "strict_min_version": "121.0"
    }
  }
}
