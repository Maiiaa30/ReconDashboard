# Copy this file to .env and fill in real values. NEVER commit .env.
# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
NODE_ENV=development

# Backend listen config
PORT=3001
HOST=0.0.0.0

# SQLite database file. Locally this resolves under backend/data/.
# In Docker, compose overrides this to the mounted volume path (/data/app.db).
DATABASE_PATH=./data/app.db

# ---------------------------------------------------------------------------
# Auth (required — the server refuses to start without these)
# ---------------------------------------------------------------------------
# Session cookie signing secret. MUST be >= 32 chars. Generate one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Single operator account, used ONLY to seed the account on first run. After the
# operator exists, the password is stored as an argon2 hash in the DB and these
# are no longer read — remove them from .env (or change your password in
# Settings → Change password, then delete these lines). Min new-password 10 chars.
ADMIN_USERNAME=operator
ADMIN_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Alerts & recon
# ---------------------------------------------------------------------------
# Discord webhook for new-subdomain alerts (Phase 2). Empty = alerting disabled.
DISCORD_WEBHOOK_URL=

# Finding scorer. Only "rules" is implemented; "ollama" is a disabled placeholder.
AI_PROVIDER=rules

# Optional LLM for DRAFTING report narrative only (scores stay deterministic).
# Any OpenAI-compatible /chat/completions endpoint. Leave blank to disable.
# Cheap/free options: Groq (https://api.groq.com/openai/v1, model
# llama-3.3-70b-versatile), Google Gemini, Cerebras, OpenRouter, or a local
# Ollama (http://localhost:11434/v1). NOTE: enabling this sends target hostnames
# and finding summaries to the configured endpoint — keep OFF for engagements
# where the attack surface must not leave your infrastructure.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional breach-data provider for the Data Leaks module (domain -> exposed
# accounts/credentials). Leave LEAK_PROVIDER blank to disable. Needs a paid API
# key you supply. Supported: hibp | dehashed | leakcheck.
#   hibp      — Have I Been Pwned 'breached domain' API. Requires an HIBP
#               subscription AND the domain verified on your HIBP account.
#               Returns which accounts appear in which breaches (no passwords).
#   dehashed  — DeHashed v2 API. Domain search; returns emails/usernames and
#               (often) plaintext/hashed passwords.
#   leakcheck — LeakCheck.io Pro API (domain-type search).
# Active domains are checked automatically once a day; passive domains are
# manual. NOTE: the domain is sent to the chosen provider — keep blank for
# engagements where that must not happen.
LEAK_PROVIDER=
LEAK_API_KEY=

# Automatic subdomain discovery interval in MINUTES. 0 = disabled (manual only).
# Keep this off or long; manual "Run discovery now" is the primary path.
SCHEDULE_SUBDOMAINS_MINUTES=0

# Retention (DAYS) for terminal job rows (done/error/cancelled/dead) in the
# activity log; older ones are pruned so the table can't grow forever. 0 disables
# pruning. Queued/running jobs and the audit_log are never pruned. Default 30.
JOBS_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Backup (Phase 8)
# ---------------------------------------------------------------------------
# Optional server-side passphrase for encrypted DB backups. If set, the backup
# button uses it automatically; if empty, the UI prompts for a passphrase each time.
BACKUP_PASSPHRASE=

# ---------------------------------------------------------------------------
# Browser capture extension (Replay → Traffic)
# ---------------------------------------------------------------------------
# Shared secret the capture browser extension presents (X-Capture-Token header)
# to POST /api/capture. The extension is a different origin and can't send the
# sameSite=strict session cookie, so it authenticates with this token instead.
# EMPTY = capture ingest is DISABLED (the route 503s) — set a long random value
# to enable, and paste the same value into the extension's options.
CAPTURE_TOKEN=
